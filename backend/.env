# 后端环境变量配置

# 调试模式
DEBUG=false

# AI 配置（通义千问 - OpenAI 兼容模式）
# 获取 API Key: https://dashscope.console.aliyun.com/
QWEN_API_KEY=sk-dcff60c19e3245e387fdfa95958dfd2e
QWEN_MODEL=qwen-turbo
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 文件配置
MAX_FILE_SIZE_MB=10

# 临时文件目录（可选，默认为项目根目录下的 .tempdocs）
# 如需自定义，推荐使用绝对路径，避免路径混乱
# WSL/Linux 示例: /home/youliang/SmartFill/.tempdocs
# Windows 示例: D:/Projects/SmartFill/.tempdocs
# 留空则使用默认值
# TEMP_DIR=

# CORS 配置（必须配置，多个地址用逗号分隔）
# 开发环境：
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# 生产环境示例：
# CORS_ORIGINS=https://your-frontend-domain.com,https://www.your-frontend-domain.com
